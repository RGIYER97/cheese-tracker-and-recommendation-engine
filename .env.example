# Path to your Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Optional: exact Google Sheets tab name with your cheese table
# (defaults to "cheese" if omitted)
CHEESE_SHEET_NAME=cheese

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model slug routed through OpenRouter.
# Good default options by model type:
# - Balanced quality/speed: openai/gpt-4.1-mini
# - Strong reasoning quality: anthropic/claude-sonnet-4
# - Lower cost option: meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Tavily API key — https://app.tavily.com/
TAVILY_API_KEY=tvly-...
